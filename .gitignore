# Terraform state — never commit
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directories
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Sensitive variable files
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config
.terraformrc
terraform.rc

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Secrets
*.pem
*.key
*.env
.env*
!.env.example
